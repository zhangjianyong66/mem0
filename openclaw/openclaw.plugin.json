{
  "id": "openclaw-mem0",
  "kind": "memory",
  "skills": [
    "skills"
  ],
  "uiHints": {
    "mode": {
      "label": "Mode",
      "help": "\"platform\" for Mem0 cloud, \"open-source\" for self-hosted"
    },
    "apiKey": {
      "label": "Mem0 API Key",
      "sensitive": true,
      "placeholder": "m0-...",
      "help": "API key from app.mem0.ai (or use ${MEM0_API_KEY}). Required for platform mode."
    },
    "defaultScope": {
      "label": "Default Scope",
      "help": "Required: userId for scoping memories. Optional: orgId/appId for organization scope."
    },
    "defaultScope.userId": {
      "label": "User ID",
      "placeholder": "alice",
      "help": "Required. Any unique identifier for the user (e.g. 'alice', 'user_123')"
    },
    "defaultScope.orgId": {
      "label": "Organization ID",
      "placeholder": "acme",
      "advanced": true,
      "help": "Optional. Organization ID for shared memories."
    },
    "defaultScope.appId": {
      "label": "Application ID",
      "placeholder": "my-app",
      "advanced": true,
      "help": "Optional. Application ID for app-specific memories."
    },
    "features": {
      "label": "Features",
      "help": "Toggle plugin features: autoRecall, autoCapture, auditLog, graph"
    },
    "features.autoRecall": {
      "label": "Auto-Recall",
      "help": "Automatically inject relevant memories before each agent turn (default: true)"
    },
    "features.autoCapture": {
      "label": "Auto-Capture",
      "help": "Automatically store conversation context after each agent turn (default: true)"
    },
    "features.auditLog": {
      "label": "Audit Log",
      "help": "Record all memory operations to SQLite audit log (default: false)"
    },
    "features.graph": {
      "label": "Graph Memory",
      "help": "Enable Mem0 graph memory for entity relationships (platform mode only, default: false)"
    },
    "projectId": {
      "label": "Project ID",
      "placeholder": "proj-...",
      "advanced": true,
      "help": "Project ID for platform mode"
    },
    "customInstructions": {
      "label": "Custom Instructions",
      "placeholder": "Only store user preferences and important facts...",
      "help": "Natural language rules for what Mem0 should store or exclude (platform mode)"
    },
    "customCategories": {
      "label": "Custom Categories",
      "advanced": true,
      "help": "Map of category names to descriptions for memory tagging (platform mode). Sensible defaults are built in."
    },
    "searchThreshold": {
      "label": "Search Threshold",
      "placeholder": "0.5",
      "help": "Minimum similarity score for search results (0-1). Default: 0.5"
    },
    "topK": {
      "label": "Top K Results",
      "placeholder": "5",
      "help": "Maximum number of memories to retrieve per recall. Default: 5"
    },
    "oss": {
      "label": "Open-Source Configuration",
      "advanced": true,
      "help": "Configure embedder, vector store, LLM, history DB for open-source mode. Has sensible defaults."
    },
    "oss.historyDbPath": {
      "label": "History DB Path",
      "placeholder": "./data/mem0_history.db",
      "help": "SQLite path for memory edit history and audit log"
    },
    "oss.disableHistory": {
      "label": "Disable History",
      "help": "Skip history DB initialization (useful when SQLite bindings fail)"
    },
    "skills": {
      "label": "Agentic Memory Skills",
      "advanced": true,
      "help": "Enable skills-based memory extraction. Disables auto-capture when active."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "platform",
          "open-source",
          "oss"
        ],
        "default": "platform"
      },
      "apiKey": {
        "type": "string"
      },
      "projectId": {
        "type": "string"
      },
      "defaultScope": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "Required. Unique identifier for the user"
          },
          "orgId": {
            "type": "string",
            "description": "Optional. Organization ID for shared memories"
          },
          "appId": {
            "type": "string",
            "description": "Optional. Application ID for app-specific memories"
          }
        },
        "required": [
          "userId"
        ],
        "additionalProperties": true
      },
      "features": {
        "type": "object",
        "properties": {
          "autoRecall": {
            "type": "boolean",
            "default": true
          },
          "autoCapture": {
            "type": "boolean",
            "default": true
          },
          "auditLog": {
            "type": "boolean",
            "default": false
          },
          "graph": {
            "type": "boolean",
            "default": false
          }
        },
        "default": {
          "autoRecall": true,
          "autoCapture": true,
          "auditLog": false,
          "graph": false
        }
      },
      "customInstructions": {
        "type": "string"
      },
      "customCategories": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "searchThreshold": {
        "type": "number",
        "default": 0.5
      },
      "topK": {
        "type": "number",
        "default": 5
      },
      "oss": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "embedder": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "provider": {
                "type": "string"
              },
              "config": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "vectorStore": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "provider": {
                "type": "string"
              },
              "config": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "llm": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "provider": {
                "type": "string"
              },
              "config": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "historyDbPath": {
            "type": "string"
          },
          "disableHistory": {
            "type": "boolean"
          }
        }
      },
      "skills": {
        "type": "object",
        "properties": {
          "triage": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "importanceThreshold": {
                "type": "number"
              },
              "enableGraph": {
                "type": "boolean"
              },
              "credentialPatterns": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "recall": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "strategy": {
                "type": "string",
                "enum": [
                  "always",
                  "smart",
                  "manual"
                ]
              },
              "tokenBudget": {
                "type": "number"
              },
              "maxMemories": {
                "type": "number"
              },
              "rerank": {
                "type": "boolean"
              },
              "keywordSearch": {
                "type": "boolean"
              },
              "filterMemories": {
                "type": "boolean"
              },
              "threshold": {
                "type": "number"
              },
              "identityAlwaysInclude": {
                "type": "boolean"
              },
              "categoryOrder": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "dream": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "schedule": {
                "type": "string"
              },
              "mergeThreshold": {
                "type": "number"
              },
              "maxMemoriesPerUser": {
                "type": "number"
              },
              "preserveImmutable": {
                "type": "boolean"
              },
              "credentialScan": {
                "type": "boolean"
              },
              "expireStaleAfterDays": {
                "type": "number"
              }
            }
          },
          "domain": {
            "type": "string"
          },
          "customRules": {
            "type": "object",
            "properties": {
              "include": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "exclude": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "categories": {
            "type": "object"
          }
        }
      }
    },
    "required": ["defaultScope"]
  },
